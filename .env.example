# Copy this file to .env and fill in the correct paths for your environment.
# The .env file is gitignored and must never be committed.

# Network drive paths for each document type.
# On Windows these are typically mapped drive letters; on Linux/macOS use UNC
# or mounted paths (e.g. /mnt/delivery-notes).
FOLDER_DELIVERY_NOTES=Z:/
FOLDER_PURCHASE_ORDERS=W:/
FOLDER_PICKING_SLIPS=Y:/
FOLDER_SHIPMENTS=X:/
